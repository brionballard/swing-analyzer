{
  "name": "swing-analyzer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based golf swing analyzer: pose (stick-man) analysis and swing tracer for face-on and down-the-line videos.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "setup": "node scripts/setup-assets.mjs",
    "postinstall": "node scripts/setup-assets.mjs",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
